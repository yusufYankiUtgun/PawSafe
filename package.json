{
  "name": "pawsafe",
  "version": "1.0.0",
  "description": "Community-driven dangerous stray animal reporting platform",
  "scripts": {
    "build:client": "esbuild src/presentation/mapPage.ts src/presentation/leaderboardPage.ts src/presentation/adminPage.ts src/presentation/authPage.ts --bundle --outdir=public/js --platform=browser",
    "dev": "npm run build:client && ts-node --transpile-only src/server.ts",
    "start": "npm run build:client && ts-node --transpile-only src/server.ts",
    "test": "jest --forceExit",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "leaflet": "^1.9.4",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/leaflet": "^1.9.8",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "esbuild": "^0.20.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/tests"],
    "testMatch": ["**/*.test.ts"],
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", { "tsconfig": "./tsconfig.test.json" }]
    },
    "collectCoverageFrom": [
      "src/business/**/*.ts",
      "src/data/**/*.ts",
      "src/api/**/*.ts"
    ]
  }
}
